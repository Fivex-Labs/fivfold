import { IsString, IsNotEmpty, IsArray, ArrayMinSize, IsOptional, IsDateString } from 'class-validator';

export class CreatePollDto {
  @IsString()
  @IsNotEmpty()
  conversationId!: string;

  @IsString()
  @IsNotEmpty()
  question!: string;

  @IsArray()
  @IsString({ each: true })
  @ArrayMinSize(2)
  options!: string[];

  @IsDateString()
  @IsOptional()
  expiresAt?: string;

  @IsOptional()
  allowMultipleAnswers?: boolean;
}
