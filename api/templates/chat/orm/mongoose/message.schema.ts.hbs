import { Schema, model, Document } from 'mongoose';

export type MessageType = 'text' | 'image' | 'video' | 'file' | 'poll' | 'location' | 'gif';
export type MessageStatus = 'sending' | 'sent' | 'delivered' | 'read' | 'failed';

export interface IMessage extends Document {
  conversationId: string;
  senderId: string;
  content?: string;
  type: MessageType;
  metadata?: Record<string, unknown>;
  readByUserIds: string[];
  replyToMessageId?: string;
  status: MessageStatus;
  deletedAt?: Date;
  createdAt: Date;
  updatedAt: Date;
}

const MessageSchema = new Schema<IMessage>(
  {
    conversationId: { type: String, required: true, index: true },
    senderId: { type: String, required: true },
    content: { type: String },
    type: { type: String, enum: ['text', 'image', 'video', 'file', 'poll', 'location', 'gif'], required: true },
    metadata: { type: Schema.Types.Mixed },
    readByUserIds: { type: [String], default: [] },
    replyToMessageId: { type: String },
    status: { type: String, enum: ['sending', 'sent', 'delivered', 'read', 'failed'], default: 'sent' },
    deletedAt: { type: Date },
  },
  { timestamps: true, collection: 'chat_messages' }
);

MessageSchema.index({ conversationId: 1, createdAt: -1 });

export const Message = model<IMessage>('ChatMessage', MessageSchema);
export { MessageSchema };
