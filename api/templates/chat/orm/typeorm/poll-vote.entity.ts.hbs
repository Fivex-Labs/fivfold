import { Entity, PrimaryGeneratedColumn, Column, CreateDateColumn, Unique, Index } from 'typeorm';

@Entity('chat_poll_votes')
@Unique(['pollId', 'userId', 'optionIndex'])
@Index(['pollId'])
export class PollVoteEntity {
  @PrimaryGeneratedColumn('uuid')
  id!: string;

  @Column({ type: 'uuid' })
  pollId!: string;

  @Column({ type: 'uuid' })
  userId!: string;

  @Column({ type: 'int' })
  optionIndex!: number;

  @CreateDateColumn()
  createdAt!: Date;
}
