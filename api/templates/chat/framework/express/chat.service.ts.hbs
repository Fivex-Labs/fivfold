{{#if (eq orm "typeorm")}}
import { DataSource, Repository, In } from 'typeorm';
import { ConversationEntity } from './entities/conversation.entity';
import { MessageEntity } from './entities/message.entity';
import { ParticipantEntity } from './entities/participant.entity';
import { AttachmentEntity } from './entities/attachment.entity';
import { PollEntity } from './entities/poll.entity';
import { PollVoteEntity } from './entities/poll-vote.entity';
import { ReactionEntity } from './entities/reaction.entity';
{{/if}}
{{#if (eq orm "mongoose")}}
import type { Model } from 'mongoose';
import { Conversation } from './schemas/conversation.schema';
import { Message } from './schemas/message.schema';
import { Participant } from './schemas/participant.schema';
import { Attachment } from './schemas/attachment.schema';
import { Poll } from './schemas/poll.schema';
import { Reaction } from './schemas/reaction.schema';
{{/if}}
{{#if (eq orm "prisma")}}
import { PrismaClient } from '@prisma/client';
{{/if}}
import type { IChatService } from './domain/chat.port';
import type { CreateMessageDto } from './dto/create-message.dto';
import type { CreateConversationDto } from './dto/create-conversation.dto';
import type { CreateGroupDto } from './dto/create-group.dto';
import type { UpdateGroupDto } from './dto/update-group.dto';
import type { AddMemberDto } from './dto/add-member.dto';
import type { RemoveMemberDto } from './dto/remove-member.dto';
import type { SendAttachmentDto } from './dto/send-attachment.dto';
import type { CreatePollDto } from './dto/create-poll.dto';
import type { VotePollDto } from './dto/vote-poll.dto';
import type { ShareLocationDto } from './dto/share-location.dto';
import type { AddReactionDto } from './dto/add-reaction.dto';
import type { SearchChatDto } from './dto/search-chat.dto';
import type { PaginationDto } from './dto/pagination.dto';

export class ChatService implements IChatService {
  {{#if (eq orm "typeorm")}}
  private readonly conversationRepo: Repository<ConversationEntity>;
  private readonly messageRepo: Repository<MessageEntity>;
  private readonly participantRepo: Repository<ParticipantEntity>;
  private readonly attachmentRepo: Repository<AttachmentEntity>;
  private readonly pollRepo: Repository<PollEntity>;
  private readonly pollVoteRepo: Repository<PollVoteEntity>;
  private readonly reactionRepo: Repository<ReactionEntity>;

  constructor(dataSource: DataSource) {
    this.conversationRepo = dataSource.getRepository(ConversationEntity);
    this.messageRepo = dataSource.getRepository(MessageEntity);
    this.participantRepo = dataSource.getRepository(ParticipantEntity);
    this.attachmentRepo = dataSource.getRepository(AttachmentEntity);
    this.pollRepo = dataSource.getRepository(PollEntity);
    this.pollVoteRepo = dataSource.getRepository(PollVoteEntity);
    this.reactionRepo = dataSource.getRepository(ReactionEntity);
  }
  {{/if}}
  {{#if (eq orm "prisma")}}
  private readonly prisma = new PrismaClient();
  {{/if}}

  async createConversation(dto: CreateConversationDto, userId: string): Promise<unknown> {
    {{#if (eq orm "typeorm")}}
    const conversation = this.conversationRepo.create({ type: 'direct' });
    const saved = await this.conversationRepo.save(conversation);
    const participantIds = [...new Set([userId, ...dto.participantIds])];
    await this.participantRepo.save(participantIds.map((uid) => this.participantRepo.create({ conversationId: saved.id, userId: uid, role: uid === userId ? 'admin' : 'member' })));
    return saved;
    {{/if}}
    {{#if (eq orm "mongoose")}}
    const conversation = await Conversation.create({ type: 'direct', pinnedByUserIds: [], mutedByUsers: {} });
    const participantIds = [...new Set([userId, ...dto.participantIds])];
    await Participant.create(participantIds.map((uid) => ({ conversationId: conversation.id, userId: uid, role: uid === userId ? 'admin' : 'member' })));
    return conversation;
    {{/if}}
    {{#if (eq orm "prisma")}}
    const participantIds = [...new Set([userId, ...dto.participantIds])];
    return this.prisma.chatConversation.create({ data: { type: 'direct', pinnedByUserIds: [], participants: { create: participantIds.map((uid) => ({ userId: uid, role: uid === userId ? 'admin' : 'member' })) } } });
    {{/if}}
  }

  async getConversations(userId: string, pagination: PaginationDto): Promise<{ items: unknown[]; total: number }> {
    const limit = pagination.limit ?? 30;
    {{#if (eq orm "typeorm")}}
    const participations = await this.participantRepo.find({ where: { userId }, take: limit });
    const ids = participations.map((p) => p.conversationId);
    const items = await this.conversationRepo.findBy({ id: In(ids) });
    return { items, total: items.length };
    {{/if}}
    {{#if (eq orm "mongoose")}}
    const participations = await Participant.find({ userId }).limit(limit);
    const ids = participations.map((p) => p.conversationId);
    const items = await Conversation.find({ _id: { $in: ids } });
    return { items, total: items.length };
    {{/if}}
    {{#if (eq orm "prisma")}}
    const participations = await this.prisma.chatParticipant.findMany({ where: { userId }, take: limit });
    const ids = participations.map((p) => p.conversationId);
    const items = await this.prisma.chatConversation.findMany({ where: { id: { in: ids } } });
    return { items, total: items.length };
    {{/if}}
  }

  async getConversation(id: string, userId: string): Promise<unknown> {
    {{#if (eq orm "typeorm")}}
    return this.conversationRepo.findOneBy({ id });
    {{/if}}
    {{#if (eq orm "mongoose")}}
    return Conversation.findById(id);
    {{/if}}
    {{#if (eq orm "prisma")}}
    return this.prisma.chatConversation.findUnique({ where: { id } });
    {{/if}}
  }

  async deleteConversation(id: string, userId: string): Promise<void> {
    {{#if (eq orm "typeorm")}}
    await this.conversationRepo.delete(id);
    {{/if}}
    {{#if (eq orm "mongoose")}}
    await Conversation.findByIdAndDelete(id);
    {{/if}}
    {{#if (eq orm "prisma")}}
    await this.prisma.chatConversation.delete({ where: { id } });
    {{/if}}
  }

  async pinConversation(conversationId: string, userId: string, pinned: boolean): Promise<void> { /* TODO */ }
  async muteConversation(conversationId: string, userId: string, mutedUntil: Date | null): Promise<void> { /* TODO */ }
  async markAsRead(conversationId: string, userId: string): Promise<void> { /* TODO */ }

  async markAsUnread(conversationId: string, userId: string): Promise<void> {
    {{#if (eq orm "typeorm")}}
    await this.participantRepo.update({ conversationId, userId }, { lastReadAt: null as unknown as Date });
    {{/if}}
    {{#if (eq orm "mongoose")}}
    await Participant.updateOne({ conversationId, userId }, { $unset: { lastReadAt: 1 } });
    {{/if}}
    {{#if (eq orm "prisma")}}
    await this.prisma.chatParticipant.update({ where: { conversationId_userId: { conversationId, userId } }, data: { lastReadAt: null } });
    {{/if}}
  }

  async clearConversationMessages(conversationId: string, userId: string): Promise<void> {
    {{#if (eq orm "typeorm")}}
    const conv = await this.conversationRepo.findOneBy({ id: conversationId });
    const me = await this.participantRepo.findOneBy({ conversationId, userId });
    if (!conv || !me) throw new Error('Not found');
    if (conv.type === 'group' && me.role !== 'admin') throw new Error('Forbidden');
    await this.messageRepo.softDelete({ conversationId });
    {{/if}}
    {{#if (eq orm "mongoose")}}
    const conv = await Conversation.findById(conversationId);
    const me = await Participant.findOne({ conversationId, userId });
    if (!conv || !me) throw new Error('Not found');
    if (conv.type === 'group' && me.role !== 'admin') throw new Error('Forbidden');
    await Message.updateMany({ conversationId, deletedAt: null }, { deletedAt: new Date() });
    {{/if}}
    {{#if (eq orm "prisma")}}
    const conv = await this.prisma.chatConversation.findUnique({ where: { id: conversationId } });
    const me = await this.prisma.chatParticipant.findUnique({ where: { conversationId_userId: { conversationId, userId } } });
    if (!conv || !me) throw new Error('Not found');
    if (conv.type === 'group' && me.role !== 'admin') throw new Error('Forbidden');
    await this.prisma.chatMessage.updateMany({ where: { conversationId, deletedAt: null }, data: { deletedAt: new Date() } });
    {{/if}}
  }

  async sendMessage(dto: CreateMessageDto, senderId: string): Promise<unknown> {
    {{#if (eq orm "typeorm")}}
    return this.messageRepo.save(this.messageRepo.create({ conversationId: dto.conversationId, senderId, content: dto.content, type: dto.type, metadata: dto.metadata, readByUserIds: [senderId], status: 'sent' }));
    {{/if}}
    {{#if (eq orm "mongoose")}}
    return Message.create({ conversationId: dto.conversationId, senderId, content: dto.content, type: dto.type, metadata: dto.metadata, readByUserIds: [senderId], status: 'sent' });
    {{/if}}
    {{#if (eq orm "prisma")}}
    return this.prisma.chatMessage.create({ data: { conversationId: dto.conversationId, senderId, content: dto.content, type: dto.type, metadata: dto.metadata ?? {}, readByUserIds: [senderId], status: 'sent' } });
    {{/if}}
  }

  async getMessages(conversationId: string, userId: string, pagination: PaginationDto): Promise<{ items: unknown[]; total: number }> {
    const limit = pagination.limit ?? 30;
    {{#if (eq orm "typeorm")}}
    const [items, total] = await this.messageRepo.findAndCount({ where: { conversationId }, order: { createdAt: 'DESC' }, take: limit });
    return { items: items.reverse(), total };
    {{/if}}
    {{#if (eq orm "mongoose")}}
    const items = await Message.find({ conversationId }).sort({ createdAt: -1 }).limit(limit);
    return { items: items.reverse(), total: items.length };
    {{/if}}
    {{#if (eq orm "prisma")}}
    const items = await this.prisma.chatMessage.findMany({ where: { conversationId }, orderBy: { createdAt: 'desc' }, take: limit });
    return { items: items.reverse(), total: items.length };
    {{/if}}
  }

  async deleteMessage(messageId: string, userId: string): Promise<void> {
    {{#if (eq orm "typeorm")}}
    await this.messageRepo.softDelete({ id: messageId });
    {{/if}}
    {{#if (eq orm "mongoose")}}
    await Message.findByIdAndUpdate(messageId, { deletedAt: new Date() });
    {{/if}}
    {{#if (eq orm "prisma")}}
    await this.prisma.chatMessage.update({ where: { id: messageId }, data: { deletedAt: new Date() } });
    {{/if}}
  }

  async createGroup(dto: CreateGroupDto, creatorId: string): Promise<unknown> {
    {{#if (eq orm "typeorm")}}
    const group = this.conversationRepo.create({ type: 'group', name: dto.name, avatarUrl: dto.avatarUrl, description: dto.description });
    const saved = await this.conversationRepo.save(group);
    const memberIds = [...new Set([creatorId, ...dto.memberIds])];
    await this.participantRepo.save(memberIds.map((uid) => this.participantRepo.create({ conversationId: saved.id, userId: uid, role: uid === creatorId ? 'admin' : 'member' })));
    return saved;
    {{/if}}
    {{#if (eq orm "mongoose")}}
    const group = await Conversation.create({ type: 'group', name: dto.name, avatarUrl: dto.avatarUrl, description: dto.description, pinnedByUserIds: [], mutedByUsers: {} });
    const memberIds = [...new Set([creatorId, ...dto.memberIds])];
    await Participant.create(memberIds.map((uid) => ({ conversationId: group.id, userId: uid, role: uid === creatorId ? 'admin' : 'member' })));
    return group;
    {{/if}}
    {{#if (eq orm "prisma")}}
    const memberIds = [...new Set([creatorId, ...dto.memberIds])];
    return this.prisma.chatConversation.create({ data: { type: 'group', name: dto.name, avatarUrl: dto.avatarUrl, pinnedByUserIds: [], participants: { create: memberIds.map((uid) => ({ userId: uid, role: uid === creatorId ? 'admin' : 'member' })) } } });
    {{/if}}
  }

  async updateGroup(groupId: string, dto: UpdateGroupDto, requesterId: string): Promise<unknown> { return {}; }
  async addMember(dto: AddMemberDto, requesterId: string): Promise<void> {}
  async removeMember(dto: RemoveMemberDto, requesterId: string): Promise<void> {}
  async updateMemberRole(conversationId: string, targetUserId: string, role: 'admin' | 'member', requesterId: string): Promise<void> {}
  async leaveGroup(conversationId: string, userId: string): Promise<void> {}
  async sendAttachment(dto: SendAttachmentDto, senderId: string): Promise<unknown> { return {}; }
  async createPoll(dto: CreatePollDto, creatorId: string): Promise<unknown> { return {}; }
  async votePoll(dto: VotePollDto, userId: string): Promise<void> {}
  async shareLocation(dto: ShareLocationDto, senderId: string): Promise<unknown> { return {}; }
  async addReaction(dto: AddReactionDto, userId: string): Promise<void> {}
  async removeReaction(messageId: string, emoji: string, userId: string): Promise<void> {}

  async searchConversations(dto: SearchChatDto, userId: string): Promise<{ conversations: unknown[]; messages: unknown[] }> {
    {{#if (eq orm "typeorm")}}
    const memberships = await this.participantRepo.find({ where: { userId }, select: ['conversationId'] });
    let allowedIds = memberships.map((m) => m.conversationId);
    if (dto.conversationId) {
      if (!allowedIds.includes(dto.conversationId)) return { conversations: [], messages: [] };
      allowedIds = [dto.conversationId];
    }
    if (!allowedIds.length) return { conversations: [], messages: [] };
    const like = `%${dto.query.toLowerCase()}%`;
    const conversations = dto.includeConversations !== false
      ? await this.conversationRepo
          .createQueryBuilder('c')
          .where('c.id IN (:...ids)', { ids: allowedIds })
          .andWhere('c.name IS NOT NULL')
          .andWhere('LOWER(c.name) LIKE :q', { q: like })
          .take(20)
          .getMany()
      : [];
    const messages = dto.includeMessages !== false
      ? await this.messageRepo
          .createQueryBuilder('m')
          .where('m.conversationId IN (:...ids)', { ids: allowedIds })
          .andWhere('m.content IS NOT NULL')
          .andWhere('LOWER(m.content) LIKE :q', { q: like })
          .take(20)
          .getMany()
      : [];
    return { conversations, messages };
    {{/if}}
    {{#if (eq orm "mongoose")}}
    const memberships = await Participant.find({ userId }).select('conversationId');
    let allowedIds = memberships.map((m) => m.conversationId);
    if (dto.conversationId) {
      if (!allowedIds.includes(dto.conversationId)) return { conversations: [], messages: [] };
      allowedIds = [dto.conversationId];
    }
    if (!allowedIds.length) return { conversations: [], messages: [] };
    const rx = new RegExp(dto.query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'i');
    const conversations = dto.includeConversations !== false
      ? await Conversation.find({ _id: { $in: allowedIds }, name: { $regex: rx } }).limit(20)
      : [];
    const messages = dto.includeMessages !== false
      ? await Message.find({ conversationId: { $in: allowedIds }, content: { $regex: rx }, deletedAt: null }).limit(20)
      : [];
    return { conversations, messages };
    {{/if}}
    {{#if (eq orm "prisma")}}
    const memberships = await this.prisma.chatParticipant.findMany({ where: { userId }, select: { conversationId: true } });
    let allowedIds = memberships.map((m) => m.conversationId);
    if (dto.conversationId) {
      if (!allowedIds.includes(dto.conversationId)) return { conversations: [], messages: [] };
      allowedIds = [dto.conversationId];
    }
    if (!allowedIds.length) return { conversations: [], messages: [] };
    const conversations = dto.includeConversations !== false
      ? await this.prisma.chatConversation.findMany({
          where: { id: { in: allowedIds }, name: { contains: dto.query, mode: 'insensitive' } },
          take: 20,
        })
      : [];
    const messages = dto.includeMessages !== false
      ? await this.prisma.chatMessage.findMany({
          where: {
            conversationId: { in: allowedIds },
            deletedAt: null,
            content: { contains: dto.query, mode: 'insensitive' },
          },
          take: 20,
        })
      : [];
    return { conversations, messages };
    {{/if}}
      }
}
