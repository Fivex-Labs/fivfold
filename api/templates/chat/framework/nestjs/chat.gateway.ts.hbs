import {
  WebSocketGateway,
  WebSocketServer,
  SubscribeMessage,
  MessageBody,
  ConnectedSocket,
  OnGatewayInit,
  OnGatewayConnection,
  OnGatewayDisconnect,
} from '@nestjs/websockets';
import { Server, Socket } from 'socket.io';
import { ChatService } from './chat.service';
import type { CreateMessageDto } from './dto/create-message.dto';
import type { AddReactionDto } from './dto/add-reaction.dto';

interface TypingPayload {
  conversationId: string;
  userId: string;
  userName?: string;
  avatarUrl?: string;
}

@WebSocketGateway({
  cors: { origin: '*' },
  namespace: '/chat',
})
export class ChatGateway implements OnGatewayInit, OnGatewayConnection, OnGatewayDisconnect {
  @WebSocketServer()
  server!: Server;

  private readonly userSocketMap = new Map<string, Set<string>>();
  private readonly presenceMap = new Map<string, boolean>();

  constructor(private readonly chatService: ChatService) {}

  afterInit(server: Server) {
    console.log('[ChatGateway] Initialized');
  }

  handleConnection(client: Socket) {
    const userId = client.handshake.query.userId as string;
    if (userId) {
      if (!this.userSocketMap.has(userId)) this.userSocketMap.set(userId, new Set());
      this.userSocketMap.get(userId)!.add(client.id);
      this.presenceMap.set(userId, true);
      this.server.emit('user:online', { userId });
    }
    console.log(`[ChatGateway] Client connected: ${client.id}`);
  }

  handleDisconnect(client: Socket) {
    const userId = client.handshake.query.userId as string;
    if (userId) {
      const sockets = this.userSocketMap.get(userId);
      if (sockets) {
        sockets.delete(client.id);
        if (sockets.size === 0) {
          this.userSocketMap.delete(userId);
          this.presenceMap.set(userId, false);
          this.server.emit('user:offline', { userId, lastSeen: new Date().toISOString() });
        }
      }
    }
    console.log(`[ChatGateway] Client disconnected: ${client.id}`);
  }

  @SubscribeMessage('conversation:join')
  async handleJoinConversation(
    @MessageBody() data: { conversationId: string },
    @ConnectedSocket() client: Socket,
  ) {
    await client.join(`conversation:${data.conversationId}`);
    client.emit('conversation:joined', { conversationId: data.conversationId });
  }

  @SubscribeMessage('conversation:leave')
  async handleLeaveConversation(
    @MessageBody() data: { conversationId: string },
    @ConnectedSocket() client: Socket,
  ) {
    await client.leave(`conversation:${data.conversationId}`);
  }

  @SubscribeMessage('message:send')
  async handleSendMessage(
    @MessageBody() data: CreateMessageDto & { senderId: string },
    @ConnectedSocket() client: Socket,
  ) {
    try {
      const { senderId, ...dto } = data;
      const message = await this.chatService.sendMessage(dto, senderId);
      this.server
        .to(`conversation:${dto.conversationId}`)
        .emit('message:new', message);
      return { success: true, message };
    } catch (err) {
      return { success: false, error: (err as Error).message };
    }
  }

  @SubscribeMessage('typing:start')
  handleTypingStart(
    @MessageBody() payload: TypingPayload,
    @ConnectedSocket() client: Socket,
  ) {
    client
      .to(`conversation:${payload.conversationId}`)
      .emit('typing:start', payload);
  }

  @SubscribeMessage('typing:stop')
  handleTypingStop(
    @MessageBody() payload: TypingPayload,
    @ConnectedSocket() client: Socket,
  ) {
    client
      .to(`conversation:${payload.conversationId}`)
      .emit('typing:stop', payload);
  }

  @SubscribeMessage('message:read')
  async handleMessageRead(
    @MessageBody() data: { conversationId: string; userId: string },
    @ConnectedSocket() client: Socket,
  ) {
    await this.chatService.markAsRead(data.conversationId, data.userId);
    client
      .to(`conversation:${data.conversationId}`)
      .emit('message:read', { conversationId: data.conversationId, userId: data.userId, readAt: new Date().toISOString() });
  }

  @SubscribeMessage('reaction:add')
  async handleAddReaction(
    @MessageBody() data: AddReactionDto & { userId: string },
    @ConnectedSocket() client: Socket,
  ) {
    try {
      const { userId, ...dto } = data;
      await this.chatService.addReaction(dto, userId);
      this.server.emit('reaction:added', { ...dto, userId });
      return { success: true };
    } catch (err) {
      return { success: false, error: (err as Error).message };
    }
  }

  @SubscribeMessage('reaction:remove')
  async handleRemoveReaction(
    @MessageBody() data: { messageId: string; emoji: string; userId: string; conversationId: string },
    @ConnectedSocket() client: Socket,
  ) {
    try {
      await this.chatService.removeReaction(data.messageId, data.emoji, data.userId);
      this.server.emit('reaction:removed', data);
      return { success: true };
    } catch (err) {
      return { success: false, error: (err as Error).message };
    }
  }

  /** Emit to all sockets of a specific user */
  emitToUser(userId: string, event: string, data: unknown) {
    const sockets = this.userSocketMap.get(userId);
    if (sockets) {
      for (const socketId of sockets) {
        this.server.to(socketId).emit(event, data);
      }
    }
  }

  /** Emit to all participants in a conversation room */
  emitToConversation(conversationId: string, event: string, data: unknown) {
    this.server.to(`conversation:${conversationId}`).emit(event, data);
  }

  isUserOnline(userId: string): boolean {
    return this.presenceMap.get(userId) ?? false;
  }
}
