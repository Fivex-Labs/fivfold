    throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement the service for your chosen database.`);
  }
  async sendEmail(_senderId: string, _senderEmail: string, _dto: Create{{moduleName}}Dto) {
    throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement the service for your chosen database.`);
  }
  async getFolders(_userId: string) {
    throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement the service for your chosen database.`);
  }
  async createFolder(_userId: string, _name: string, _icon?: string) {
    throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement the service for your chosen database.`);
  }
  async deleteFolder(_userId: string, _folderId: string) {
    throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement the service for your chosen database.`);
  }
  async getLabels(_userId: string) {
    throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement the service for your chosen database.`);
  }
  async createLabel(_userId: string, _name: string, _color?: string) {
