import { Router, type Request, type Response, type NextFunction } from 'express';
import { {{moduleName}}Service } from './{{kitName}}.service';

// Replace this middleware with your actual authentication middleware.
// It should set req.user = { id: string, email: string }
function authMiddleware(req: Request, res: Response, next: NextFunction): void {
  // TODO: Replace with your auth check, e.g. JWT verification
  // const user = verifyJwt(req.headers.authorization);
  // if (!user) { res.status(401).json({ error: 'Unauthorized' }); return; }
  // (req as any).user = user;
  next();
}

function getUser(req: Request): { id: string; email: string } {
  // TODO: Return actual user from req after auth middleware
  return (req as any).user ?? { id: 'REPLACE_WITH_USER_ID', email: 'user@example.com' };
}

/** Create router with injected service. Use create{{moduleName}}Service(connection) to create the service. */
export function create{{moduleName}}Router(service: {{moduleName}}Service): Router {
  const router = Router();

  router.use(authMiddleware);

  // GET /{{kitName}}/threads
  router.get('/threads', async (req, res) => {
    try {
      const user = getUser(req);
      const result = await service.getThreads(user.id, req.query as any);
      res.json(result);
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  // GET /{{kitName}}/threads/:id
  router.get('/threads/:id', async (req, res) => {
    try {
      const user = getUser(req);
      const thread = await service.getThread(user.id, req.params['id']!);
      if (!thread) return res.status(404).json({ error: 'Not found' });
      res.json(thread);
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  // PATCH /{{kitName}}/threads/:id
  router.patch('/threads/:id', async (req, res) => {
    try {
      const user = getUser(req);
      const thread = await service.updateThread(user.id, req.params['id']!, req.body);
      res.json(thread);
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  // DELETE /{{kitName}}/threads/:id
  router.delete('/threads/:id', async (req, res) => {
    try {
      const user = getUser(req);
      await service.deleteThread(user.id, req.params['id']!);
      res.status(204).send();
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  // POST /{{kitName}}/send
  router.post('/send', async (req, res) => {
    try {
      const user = getUser(req);
      const result = await service.sendEmail(user.id, user.email, req.body);
      res.status(201).json(result);
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  // GET /{{kitName}}/folders
  router.get('/folders', async (req, res) => {
    try {
      const user = getUser(req);
      const folders = await service.getFolders(user.id);
      res.json(folders);
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  // POST /{{kitName}}/folders
  router.post('/folders', async (req, res) => {
    try {
      const user = getUser(req);
      const { name, icon } = req.body;
      const folder = await service.createFolder(user.id, name, icon);
      res.status(201).json(folder);
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  // DELETE /{{kitName}}/folders/:id
  router.delete('/folders/:id', async (req, res) => {
    try {
      const user = getUser(req);
      await service.deleteFolder(user.id, req.params['id']!);
      res.status(204).send();
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  // GET /{{kitName}}/labels
  router.get('/labels', async (req, res) => {
    try {
      const user = getUser(req);
      const labels = await service.getLabels(user.id);
      res.json(labels);
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  // POST /{{kitName}}/labels
  router.post('/labels', async (req, res) => {
    try {
      const user = getUser(req);
      const { name, color } = req.body;
      const label = await service.createLabel(user.id, name, color);
      res.status(201).json(label);
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  // DELETE /{{kitName}}/labels/:id
  router.delete('/labels/:id', async (req, res) => {
    try {
      const user = getUser(req);
      await service.deleteLabel(user.id, req.params['id']!);
      res.status(204).send();
    } catch (err) {
      res.status(500).json({ error: String(err) });
    }
  });

  return router;
}
