
// Stripe Kit — generated by FivFold
{{#if (hasFeature kitFeatures "payments")}}
model StripeCustomer {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  stripeCustomerId String   @unique @map("stripe_customer_id")
  email            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("stripe_customers")
}

model StripePaymentTransaction {
  id                    String   @id @default(uuid())
  cartId                String   @map("cart_id")
  userId                String?  @map("user_id")
  stripePaymentIntentId String   @unique @map("stripe_payment_intent_id")
  amountCents           Int      @map("amount_cents")
  currency              String
  status                String   @default("requires_payment_method")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([cartId])
  @@index([userId])
  @@map("stripe_payment_transactions")
}
{{/if}}
{{#if (hasFeature kitFeatures "webhooks")}}
model StripeWebhookEvent {
  stripeEventId String    @id @map("stripe_event_id")
  type          String
  status        String    @default("received")
  lastError     String?   @map("last_error")
  receivedAt    DateTime  @default(now()) @map("received_at")
  processedAt   DateTime? @map("processed_at")

  @@map("stripe_webhook_events")
}
{{/if}}
{{#if (hasFeature kitFeatures "connect")}}
model StripeConnectedAccount {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  stripeAccountId  String   @unique @map("stripe_account_id")
  payoutsEnabled   Boolean  @default(false) @map("payouts_enabled")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("stripe_connected_accounts")
}
{{/if}}
