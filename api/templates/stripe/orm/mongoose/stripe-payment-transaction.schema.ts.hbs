import { Schema, model, type Document } from 'mongoose';

export interface StripePaymentTransactionDoc extends Document {
  cartId: string;
  userId?: string | null;
  stripePaymentIntentId: string;
  amountCents: number;
  currency: string;
  status: string;
  createdAt: Date;
}

const StripePaymentTransactionSchema = new Schema<StripePaymentTransactionDoc>(
  {
    cartId: { type: String, required: true, index: true },
    userId: { type: String, index: true },
    stripePaymentIntentId: { type: String, required: true, unique: true },
    amountCents: { type: Number, required: true },
    currency: { type: String, required: true },
    status: { type: String, default: 'requires_payment_method' },
  },
  { timestamps: { createdAt: true, updatedAt: false }, collection: 'stripe_payment_transactions' }
);

export const StripePaymentTransactionModel = model<StripePaymentTransactionDoc>(
  'StripePaymentTransaction',
  StripePaymentTransactionSchema
);
export { StripePaymentTransactionSchema };
