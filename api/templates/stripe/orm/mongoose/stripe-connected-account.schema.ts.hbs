import { Schema, model, type Document } from 'mongoose';

export interface StripeConnectedAccountDoc extends Document {
  userId: string;
  stripeAccountId: string;
  payoutsEnabled: boolean;
  createdAt: Date;
  updatedAt: Date;
}

const StripeConnectedAccountSchema = new Schema<StripeConnectedAccountDoc>(
  {
    userId: { type: String, required: true, unique: true, index: true },
    stripeAccountId: { type: String, required: true, unique: true, index: true },
    payoutsEnabled: { type: Boolean, default: false },
  },
  { timestamps: true, collection: 'stripe_connected_accounts' }
);

export const StripeConnectedAccountModel = model<StripeConnectedAccountDoc>(
  'StripeConnectedAccount',
  StripeConnectedAccountSchema
);
export { StripeConnectedAccountSchema };
