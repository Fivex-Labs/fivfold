import { Injectable, BadRequestException } from '@nestjs/common';
import { plainToInstance } from 'class-transformer';
import { validate } from 'class-validator';
import { StripeNodeAdapter } from './adapters/stripe-node.adapter';
{{#if (hasFeature kitFeatures "payments")}}
import { CreateStripeCustomerDto } from './dto/create-customer.dto';
import { CreatePaymentIntentDto } from './dto/create-payment-intent.dto';
{{/if}}
{{#if (hasFeature kitFeatures "checkout")}}
import { CreateCheckoutSessionDto } from './dto/create-checkout-session.dto';
{{/if}}
{{#if (hasFeature kitFeatures "connect")}}
import { CreateConnectAccountDto } from './dto/create-connect-account.dto';
import { CreateAccountLinkDto } from './dto/create-account-link.dto';
{{/if}}
{{#if (hasFeature kitFeatures "billing")}}
import { CreateSubscriptionDto } from './dto/create-subscription.dto';
import { CreatePortalSessionDto } from './dto/create-portal-session.dto';
{{/if}}
{{#if (eq orm "typeorm")}}
import { InjectRepository } from '@nestjs/typeorm';
import { Repository } from 'typeorm';
{{#if (hasFeature kitFeatures "payments")}}
import { StripeCustomer } from './entities/stripe-customer.entity';
import { StripePaymentTransaction } from './entities/stripe-payment-transaction.entity';
{{/if}}
{{#if (hasFeature kitFeatures "webhooks")}}
import { StripeWebhookEvent } from './entities/stripe-webhook-event.entity';
{{/if}}
{{#if (hasFeature kitFeatures "connect")}}
import { StripeConnectedAccount } from './entities/stripe-connected-account.entity';
{{/if}}
{{/if}}
{{#if (eq orm "prisma")}}
import { PrismaService } from '../../prisma.service';
{{/if}}
{{#if (eq orm "mongoose")}}
import { InjectModel } from '@nestjs/mongoose';
import { Model } from 'mongoose';
{{#if (hasFeature kitFeatures "payments")}}
import { StripeCustomerModel, type StripeCustomerDoc } from './schemas/stripe-customer.schema';
import {
  StripePaymentTransactionModel,
  type StripePaymentTransactionDoc,
} from './schemas/stripe-payment-transaction.schema';
{{/if}}
{{#if (hasFeature kitFeatures "webhooks")}}
import { StripeWebhookEventModel, type StripeWebhookEventDoc } from './schemas/stripe-webhook-event.schema';
{{/if}}
{{#if (hasFeature kitFeatures "connect")}}
import {
  StripeConnectedAccountModel,
  type StripeConnectedAccountDoc,
} from './schemas/stripe-connected-account.schema';
{{/if}}
{{/if}}

async function validateDto<T extends object>(DtoClass: new () => T, body: unknown): Promise<T> {
  const dto = plainToInstance(DtoClass, body);
  const errors = await validate(dto as object);
  if (errors.length > 0) {
    const msg = errors.map((e) => Object.values(e.constraints ?? {}).join(', ')).join('; ');
    throw new BadRequestException(msg);
  }
  return dto;
}

async function resolveCartTotalCents(_cartId: string): Promise<number> {
  return Number(process.env.STRIPE_DEV_FIXTURE_AMOUNT_CENTS ?? '1000');
}

@Injectable()
export class {{moduleName}}Service {
  private readonly stripe = new StripeNodeAdapter();

  constructor(
    {{#if (eq orm "typeorm")}}
    {{#if (hasFeature kitFeatures "payments")}}
    @InjectRepository(StripeCustomer)
    private readonly customerRepo: Repository<StripeCustomer>,
    @InjectRepository(StripePaymentTransaction)
    private readonly paymentTxRepo: Repository<StripePaymentTransaction>,
    {{/if}}
    {{#if (hasFeature kitFeatures "webhooks")}}
    @InjectRepository(StripeWebhookEvent)
    private readonly webhookRepo: Repository<StripeWebhookEvent>,
    {{/if}}
    {{#if (hasFeature kitFeatures "connect")}}
    @InjectRepository(StripeConnectedAccount)
    private readonly connectRepo: Repository<StripeConnectedAccount>,
    {{/if}}
    {{/if}}
    {{#if (eq orm "prisma")}}
    private readonly prisma: PrismaService,
    {{/if}}
    {{#if (eq orm "mongoose")}}
    {{#if (hasFeature kitFeatures "payments")}}
    @InjectModel('StripeCustomer')
    private readonly customerModel: Model<StripeCustomerDoc>,
    @InjectModel('StripePaymentTransaction')
    private readonly paymentTxModel: Model<StripePaymentTransactionDoc>,
    {{/if}}
    {{#if (hasFeature kitFeatures "webhooks")}}
    @InjectModel('StripeWebhookEvent')
    private readonly webhookModel: Model<StripeWebhookEventDoc>,
    {{/if}}
    {{#if (hasFeature kitFeatures "connect")}}
    @InjectModel('StripeConnectedAccount')
    private readonly connectModel: Model<StripeConnectedAccountDoc>,
    {{/if}}
    {{/if}}
  ) {}

  {{#if (hasFeature kitFeatures "payments")}}
  async createCustomer(userId: string, body: unknown) {
    const dto = await validateDto(CreateStripeCustomerDto, body);
    const customer = await this.stripe.createCustomer({
      email: dto.email,
      name: dto.name,
      metadata: dto.metadata,
    });
    {{#if (eq orm "typeorm")}}
    await this.customerRepo.save(
      this.customerRepo.create({
        userId,
        stripeCustomerId: customer.id,
        email: dto.email,
      })
    );
    {{/if}}
    {{#if (eq orm "prisma")}}
    await this.prisma.stripeCustomer.upsert({
      where: { userId },
      create: { userId, stripeCustomerId: customer.id, email: dto.email },
      update: { stripeCustomerId: customer.id, email: dto.email },
    });
    {{/if}}
    {{#if (eq orm "mongoose")}}
    await this.customerModel.findOneAndUpdate(
      { userId },
      { userId, stripeCustomerId: customer.id, email: dto.email },
      { upsert: true, new: true }
    );
    {{/if}}
    return { customerId: customer.id };
  }

  async createPaymentIntent(userId: string | null, body: unknown) {
    const dto = await validateDto(CreatePaymentIntentDto, body);
    const amountCents = await resolveCartTotalCents(dto.cartId);
    const currency = (process.env.STRIPE_DEFAULT_CURRENCY ?? 'usd').toLowerCase();
    const pi = await this.stripe.createPaymentIntent({
      amountCents,
      currency,
      metadata: { cartId: dto.cartId, userId: userId ?? '' },
      stripeAccountId: dto.stripeAccountId,
    });
    {{#if (eq orm "typeorm")}}
    await this.paymentTxRepo.save(
      this.paymentTxRepo.create({
        cartId: dto.cartId,
        userId,
        stripePaymentIntentId: pi.id,
        amountCents,
        currency,
        status: pi.status,
      })
    );
    {{/if}}
    {{#if (eq orm "prisma")}}
    await this.prisma.stripePaymentTransaction.create({
      data: {
        cartId: dto.cartId,
        userId,
        stripePaymentIntentId: pi.id,
        amountCents,
        currency,
        status: pi.status,
      },
    });
    {{/if}}
    {{#if (eq orm "mongoose")}}
    await this.paymentTxModel.create({
      cartId: dto.cartId,
      userId,
      stripePaymentIntentId: pi.id,
      amountCents,
      currency,
      status: pi.status,
    });
    {{/if}}
    return {
      clientSecret: pi.client_secret,
      paymentIntentId: pi.id,
      amountCents,
      currency,
    };
  }
  {{/if}}

  {{#if (hasFeature kitFeatures "checkout")}}
  async createCheckoutSession(userId: string | null, body: unknown) {
    const dto = await validateDto(CreateCheckoutSessionDto, body);
    const qty = dto.quantity ? Number(dto.quantity) : 1;
    const session = await this.stripe.createCheckoutSession({
      mode: dto.mode,
      lineItems: [{ price: dto.priceId, quantity: qty }],
      successUrl: dto.successUrl,
      cancelUrl: dto.cancelUrl,
      customerId: dto.customerId,
      metadata: userId ? { userId } : undefined,
      stripeAccountId: dto.stripeAccountId,
    });
    return { url: session.url, sessionId: session.id };
  }
  {{/if}}

  {{#if (hasFeature kitFeatures "connect")}}
  async createConnectedAccount(userId: string, body: unknown) {
    const dto = await validateDto(CreateConnectAccountDto, body);
    const acct = await this.stripe.createExpressConnectedAccount({
      email: dto.email,
      metadata: { ...dto.metadata, userId },
    });
    {{#if (eq orm "typeorm")}}
    await this.connectRepo.save(
      this.connectRepo.create({
        userId,
        stripeAccountId: acct.id,
        payoutsEnabled: acct.payouts_enabled ?? false,
      })
    );
    {{/if}}
    {{#if (eq orm "prisma")}}
    await this.prisma.stripeConnectedAccount.upsert({
      where: { userId },
      create: {
        userId,
        stripeAccountId: acct.id,
        payoutsEnabled: acct.payouts_enabled ?? false,
      },
      update: { stripeAccountId: acct.id, payoutsEnabled: acct.payouts_enabled ?? false },
    });
    {{/if}}
    {{#if (eq orm "mongoose")}}
    await this.connectModel.findOneAndUpdate(
      { userId },
      {
        userId,
        stripeAccountId: acct.id,
        payoutsEnabled: acct.payouts_enabled ?? false,
      },
      { upsert: true, new: true }
    );
    {{/if}}
    return { accountId: acct.id };
  }

  async createAccountLink(_userId: string, body: unknown) {
    const dto = await validateDto(CreateAccountLinkDto, body);
    const link = await this.stripe.createAccountLink({
      accountId: dto.accountId,
      refreshUrl: dto.refreshUrl,
      returnUrl: dto.returnUrl,
      type: dto.type,
    });
    return { url: link.url };
  }
  {{/if}}

  {{#if (hasFeature kitFeatures "billing")}}
  async createSubscription(_userId: string, body: unknown) {
    const dto = await validateDto(CreateSubscriptionDto, body);
    const sub = await this.stripe.createSubscription({
      customerId: dto.customerId,
      priceId: dto.priceId,
      metadata: dto.metadata,
    });
    return { subscriptionId: sub.id, status: sub.status };
  }

  async createPortalSession(_userId: string, body: unknown) {
    const dto = await validateDto(CreatePortalSessionDto, body);
    const session = await this.stripe.createBillingPortalSession({
      customerId: dto.customerId,
      returnUrl: dto.returnUrl,
    });
    return { url: session.url };
  }
  {{/if}}

  {{#if (hasFeature kitFeatures "webhooks")}}
  async processWebhook(rawBody: Buffer, signature: string | string[] | undefined) {
    const event = this.stripe.constructWebhookEvent(rawBody, signature);
    {{#if (eq orm "typeorm")}}
    const existing = await this.webhookRepo.findOne({ where: { stripeEventId: event.id } });
    if (existing?.status === 'processed') return { received: true, duplicate: true };
    if (!existing) {
      await this.webhookRepo.save(
        this.webhookRepo.create({
          stripeEventId: event.id,
          type: event.type,
          status: 'received',
        })
      );
    }
    {{#if (hasFeature kitFeatures "payments")}}
    if (event.type === 'payment_intent.succeeded') {
      const pi = event.data.object as { id: string };
      await this.paymentTxRepo.update(
        { stripePaymentIntentId: pi.id },
        { status: 'succeeded' }
      );
    }
    {{/if}}
    {{#if (hasFeature kitFeatures "connect")}}
    if (event.type === 'account.updated') {
      const acct = event.data.object as { id: string; payouts_enabled?: boolean };
      await this.connectRepo.update(
        { stripeAccountId: acct.id },
        { payoutsEnabled: acct.payouts_enabled ?? false }
      );
    }
    {{/if}}
    await this.webhookRepo.update(
      { stripeEventId: event.id },
      { status: 'processed', processedAt: new Date(), lastError: null }
    );
    {{/if}}
    {{#if (eq orm "prisma")}}
    const existing = await this.prisma.stripeWebhookEvent.findUnique({
      where: { stripeEventId: event.id },
    });
    if (existing?.status === 'processed') return { received: true, duplicate: true };
    await this.prisma.stripeWebhookEvent.upsert({
      where: { stripeEventId: event.id },
      create: { stripeEventId: event.id, type: event.type, status: 'received' },
      update: {},
    });
    {{#if (hasFeature kitFeatures "payments")}}
    if (event.type === 'payment_intent.succeeded') {
      const pi = event.data.object as { id: string };
      await this.prisma.stripePaymentTransaction.updateMany({
        where: { stripePaymentIntentId: pi.id },
        data: { status: 'succeeded' },
      });
    }
    {{/if}}
    {{#if (hasFeature kitFeatures "connect")}}
    if (event.type === 'account.updated') {
      const acct = event.data.object as { id: string; payouts_enabled?: boolean };
      await this.prisma.stripeConnectedAccount.updateMany({
        where: { stripeAccountId: acct.id },
        data: { payoutsEnabled: acct.payouts_enabled ?? false },
      });
    }
    {{/if}}
    await this.prisma.stripeWebhookEvent.update({
      where: { stripeEventId: event.id },
      data: { status: 'processed', processedAt: new Date() },
    });
    {{/if}}
    {{#if (eq orm "mongoose")}}
    const existing = await this.webhookModel.findOne({ stripeEventId: event.id });
    if (existing?.status === 'processed') return { received: true, duplicate: true };
    await this.webhookModel.findOneAndUpdate(
      { stripeEventId: event.id },
      { stripeEventId: event.id, type: event.type, status: 'received' },
      { upsert: true, new: true }
    );
    {{#if (hasFeature kitFeatures "payments")}}
    if (event.type === 'payment_intent.succeeded') {
      const pi = event.data.object as { id: string };
      await this.paymentTxModel.updateMany(
        { stripePaymentIntentId: pi.id },
        { status: 'succeeded' }
      );
    }
    {{/if}}
    {{#if (hasFeature kitFeatures "connect")}}
    if (event.type === 'account.updated') {
      const acct = event.data.object as { id: string; payouts_enabled?: boolean };
      await this.connectModel.updateMany(
        { stripeAccountId: acct.id },
        { payoutsEnabled: acct.payouts_enabled ?? false }
      );
    }
    {{/if}}
    await this.webhookModel.updateOne(
      { stripeEventId: event.id },
      { status: 'processed', processedAt: new Date() }
    );
    {{/if}}
    return { received: true };
  }
  {{/if}}
}
{{/if}}

