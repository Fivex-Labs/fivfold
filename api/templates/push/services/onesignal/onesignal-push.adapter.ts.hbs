import axios from 'axios';
import type { SendNotificationDto } from '../dto/send-notification.dto';
import type { SendResult } from '../domain/push.port';

const ONESIGNAL_API = 'https://api.onesignal.com/notifications';

export class OneSignalPushAdapter {
  private appId: string;
  private restApiKey: string;

  constructor() {
    this.appId = process.env.ONESIGNAL_APP_ID ?? '';
    this.restApiKey = process.env.ONESIGNAL_REST_API_KEY ?? '';
  }

  async sendToDevice(token: string, payload: SendNotificationDto): Promise<SendResult> {
    try {
      const res = await axios.post(
        ONESIGNAL_API,
        {
          app_id: this.appId,
          include_player_ids: [token],
          headings: { en: payload.title },
          contents: { en: payload.body ?? '' },
          data: payload.data,
          big_picture: payload.imageUrl,
          ios_badgeType: payload.badge != null ? 'SetTo' : undefined,
          ios_badgeCount: payload.badge,
          android_channel_id: payload.channelId,
        },
        {
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Basic ${this.restApiKey}`,
          },
        }
      );
      const messageId = res.data?.id;
      return { success: true, messageId };
    } catch (err: any) {
      return { success: false, error: err?.response?.data?.errors?.[0] ?? String(err) };
    }
  }

  async sendToTopic(topic: string, payload: SendNotificationDto): Promise<SendResult> {
    try {
      const res = await axios.post(
        ONESIGNAL_API,
        {
          app_id: this.appId,
          filters: [{ field: 'tag', key: 'topic', value: topic }],
          headings: { en: payload.title },
          contents: { en: payload.body ?? '' },
          data: { ...payload.data, topic },
        },
        {
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Basic ${this.restApiKey}`,
          },
        }
      );
      const messageId = res.data?.id;
      return { success: true, messageId };
    } catch (err: any) {
      return { success: false, error: err?.response?.data?.errors?.[0] ?? String(err) };
    }
  }
}
