{{#if (eq orm "typeorm")}}
import { DataSource, Repository } from 'typeorm';
import { PushSubscription } from './entities/push-subscription.entity';
import { PushNotificationLog } from './entities/notification-log.entity';
{{/if}}
import type { RegisterDeviceDto } from './dto/register-device.dto';
import type { SendNotificationDto } from './dto/send-notification.dto';
{{#if provider}}
import { {{providerNamePascal}}PushAdapter } from './adapters/{{provider}}-push.adapter';
{{/if}}

export function create{{moduleName}}Service({{#if (eq orm "typeorm")}}dataSource: DataSource{{else}}_connection?: unknown{{/if}}) {
  {{#if (eq orm "typeorm")}}
  const subscriptionRepo = dataSource.getRepository(PushSubscription);
  const logRepo = dataSource.getRepository(PushNotificationLog);
  {{#if provider}}
  const pushAdapter = new {{providerNamePascal}}PushAdapter();
  {{/if}}

  return {
    async registerDevice(userId: string, dto: RegisterDeviceDto) {
      const existing = await subscriptionRepo.findOne({
        where: { userId, token: dto.token },
      });
      if (existing) {
        existing.platform = dto.platform;
        existing.metadata = dto.metadata ?? null;
        return subscriptionRepo.save(existing);
      }
      const sub = subscriptionRepo.create({
        userId,
        token: dto.token,
        platform: dto.platform,
        provider: '{{provider}}',
        metadata: dto.metadata ?? null,
      });
      return subscriptionRepo.save(sub);
    },

    async unregisterDevice(userId: string, token: string): Promise<void> {
      await subscriptionRepo.delete({ userId, token });
    },

    async sendToDevice(token: string, payload: SendNotificationDto) {
      {{#if provider}}
      return pushAdapter.sendToDevice(token, payload);
      {{else}}
      throw new Error('No push provider configured');
      {{/if}}
    },

    async sendToUser(userId: string, payload: SendNotificationDto) {
      {{#if provider}}
      const subs = await subscriptionRepo.find({ where: { userId } });
      if (subs.length === 0) throw new Error('No devices registered');
      const results = await Promise.all(
        subs.map((s) => pushAdapter.sendToDevice(s.token, payload))
      );
      return results[0] ?? { success: false, error: 'No devices' };
      {{else}}
      throw new Error('No push provider configured');
      {{/if}}
    },

    async sendToTopic(topic: string, payload: SendNotificationDto) {
      {{#if provider}}
      return pushAdapter.sendToTopic(topic, payload);
      {{else}}
      throw new Error('No push provider configured');
      {{/if}}
    },

    async getSubscriptions(userId: string) {
      return subscriptionRepo.find({
        where: { userId },
        order: { createdAt: 'DESC' },
      });
    },

    async logNotification(
      subscriptionId: string,
      messageId: string | null,
      status: 'sent' | 'failed',
      error?: string
    ): Promise<void> {
      await logRepo.save(
        logRepo.create({
          subscriptionId,
          messageId,
          status,
          error: error ?? null,
          provider: '{{provider}}',
        })
      );
    },
  };
  {{else}}
  const stub = (): never => { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); };
  return {
    registerDevice: stub,
    unregisterDevice: stub,
    sendToDevice: {{#if provider}}async (token: string, payload: SendNotificationDto) => new {{providerNamePascal}}PushAdapter().sendToDevice(token, payload),{{else}}stub,{{/if}}
    sendToUser: {{#if provider}}async (userId: string, payload: SendNotificationDto) => { const subs: never[] = []; if (subs.length === 0) throw new Error('No devices registered'); return { success: false }; },{{else}}stub,{{/if}}
    sendToTopic: {{#if provider}}async (topic: string, payload: SendNotificationDto) => new {{providerNamePascal}}PushAdapter().sendToTopic(topic, payload),{{else}}stub,{{/if}}
    getSubscriptions: stub,
    logNotification: stub,
  };
  {{/if}}
}
