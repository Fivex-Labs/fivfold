import {
  Entity,
  PrimaryGeneratedColumn,
  Column,
  CreateDateColumn,
  UpdateDateColumn,
  ManyToOne,
  JoinColumn,
} from 'typeorm';
import { KanbanColumn } from './column.entity';

export type TaskPriority = 'low' | 'medium' | 'high' | 'urgent';

@Entity('kanban_tasks')
export class KanbanTask {
  @PrimaryGeneratedColumn('uuid')
  id: string;

  @Column({ type: 'varchar', length: 500 })
  title: string;

  @Column({ type: 'text', nullable: true })
  description: string | null;

  @Column({ type: 'varchar', name: 'column_id' })
  columnId: string;

  @ManyToOne(() => KanbanColumn, (col) => col.tasks, { onDelete: 'CASCADE' })
  @JoinColumn({ name: 'column_id' })
  column: KanbanColumn;

  @Column({ type: 'varchar', default: 'medium' })
  priority: TaskPriority;

  @Column({ type: 'varchar', name: 'assignee_id', nullable: true })
  assigneeId: string | null; // Replace with FK to your User entity

  @Column({ type: 'date', name: 'due_date', nullable: true })
  dueDate: Date | null;

  @Column({ type: 'decimal', name: 'estimated_hours', precision: 5, scale: 1, nullable: true })
  estimatedHours: number | null;

  @Column({ type: 'decimal', name: 'actual_hours', precision: 5, scale: 1, nullable: true })
  actualHours: number | null;

  @Column({ type: 'simple-array', nullable: true })
  labels: string[];

  @Column({ type: 'int', default: 0 })
  position: number;

  @CreateDateColumn({ name: 'created_at' })
  createdAt: Date;

  @UpdateDateColumn({ name: 'updated_at' })
  updatedAt: Date;
}
