import {
  DynamoDBClient,
  CreateTableCommand,
  CreateTableCommandInput,
} from '@aws-sdk/client-dynamodb';
import { DynamoDBDocumentClient, PutCommand, GetCommand, QueryCommand, UpdateCommand, DeleteCommand } from '@aws-sdk/lib-dynamodb';

const region = process.env.AWS_REGION ?? 'us-east-1';
const rawClient = new DynamoDBClient({ region });
export const dynamo = DynamoDBDocumentClient.from(rawClient);

export const TABLE_NAMES = {
  BOARDS: '{{kitName}}_boards',
  COLUMNS: '{{kitName}}_columns',
  TASKS: '{{kitName}}_tasks',
  LABELS: '{{kitName}}_labels',
} as const;

export interface {{moduleName}}BoardItem {
  PK: string;       // USER#<ownerId>
  SK: string;       // BOARD#<id>
  id: string;
  title: string;
  description?: string | null;
  ownerId: string;
  coverColor?: string | null;
  createdAt: string;
  updatedAt: string;
}

export interface {{moduleName}}ColumnItem {
  PK: string;       // BOARD#<boardId>
  SK: string;       // COLUMN#<position>#<id>
  id: string;
  title: string;
  description?: string | null;
  boardId: string;
  position: number;
  maxTasks?: number | null;
  color?: string | null;
  createdAt: string;
  updatedAt: string;
}

export interface {{moduleName}}TaskItem {
  PK: string;       // COLUMN#<columnId>
  SK: string;       // TASK#<position>#<id>
  id: string;
  title: string;
  description?: string | null;
  columnId: string;
  priority: string;
  assigneeId?: string | null;
  dueDate?: string | null;
  estimatedHours?: number | null;
  actualHours?: number | null;
  labels: string[];
  position: number;
  createdAt: string;
  updatedAt: string;
}

