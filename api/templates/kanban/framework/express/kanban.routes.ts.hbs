import { Router, type Request, type Response, type NextFunction } from 'express';
import { {{moduleName}}Service } from './{{kitName}}.service';

// Replace with your actual authentication middleware
function authMiddleware(req: Request, res: Response, next: NextFunction): void {
  // TODO: Replace with your auth check
  next();
}

function getUser(req: Request): { id: string } {
  return (req as any).user ?? { id: 'REPLACE_WITH_USER_ID' };
}

/** Create router with injected service. Use create{{moduleName}}Service(connection) to create the service. */
export function create{{moduleName}}Router(service: {{moduleName}}Service): Router {
  const router = Router();

  router.use(authMiddleware);

  // GET /{{kitName}}/boards
  router.get('/boards', async (req, res) => {
    try {
      res.json(await service.getBoards(getUser(req).id));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // GET /{{kitName}}/boards/:boardId
  router.get('/boards/:boardId', async (req, res) => {
    try {
      const board = await service.getBoard(getUser(req).id, req.params['boardId']!);
      if (!board) return res.status(404).json({ error: 'Not found' });
      res.json(board);
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // POST /{{kitName}}/boards
  router.post('/boards', async (req, res) => {
    try {
      const { title, description } = req.body;
      res.status(201).json(await service.createBoard(getUser(req).id, title, description));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // DELETE /{{kitName}}/boards/:boardId
  router.delete('/boards/:boardId', async (req, res) => {
    try {
      await service.deleteBoard(getUser(req).id, req.params['boardId']!);
      res.status(204).send();
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // POST /{{kitName}}/boards/:boardId/columns
  router.post('/boards/:boardId/columns', async (req, res) => {
    try {
      const { title, color, maxTasks } = req.body;
      res.status(201).json(
        await service.createColumn(getUser(req).id, req.params['boardId']!, title, color, maxTasks)
      );
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // PATCH /{{kitName}}/boards/:boardId/columns/reorder
  router.patch('/boards/:boardId/columns/reorder', async (req, res) => {
    try {
      await service.updateColumnPositions(getUser(req).id, req.params['boardId']!, req.body.columns);
      res.status(204).send();
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // DELETE /{{kitName}}/boards/:boardId/columns/:columnId
  router.delete('/boards/:boardId/columns/:columnId', async (req, res) => {
    try {
      await service.deleteColumn(getUser(req).id, req.params['boardId']!, req.params['columnId']!);
      res.status(204).send();
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // POST /{{kitName}}/tasks
  router.post('/tasks', async (req, res) => {
    try {
      res.status(201).json(await service.createTask(req.body));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // PATCH /{{kitName}}/tasks/:taskId
  router.patch('/tasks/:taskId', async (req, res) => {
    try {
      res.json(await service.updateTask(req.params['taskId']!, req.body));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // PATCH /{{kitName}}/tasks/:taskId/move
  router.patch('/tasks/:taskId/move', async (req, res) => {
    try {
      const { columnId, position } = req.body;
      res.json(await service.moveTask(req.params['taskId']!, columnId, position));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // DELETE /{{kitName}}/tasks/:taskId
  router.delete('/tasks/:taskId', async (req, res) => {
    try {
      await service.deleteTask(req.params['taskId']!);
      res.status(204).send();
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // GET /{{kitName}}/boards/:boardId/labels
  router.get('/boards/:boardId/labels', async (req, res) => {
    try {
      res.json(await service.getLabels(req.params['boardId']!));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // POST /{{kitName}}/boards/:boardId/labels
  router.post('/boards/:boardId/labels', async (req, res) => {
    try {
      const { name, color } = req.body;
      res.status(201).json(await service.createLabel(req.params['boardId']!, name, color));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  return router;
}
