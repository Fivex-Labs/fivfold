  async updateColumnPositions(_userId: string, _boardId: string, _columnOrders: { id: string; position: number }[]): Promise<void> { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async deleteColumn(_userId: string, _boardId: string, _columnId: string): Promise<void> { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async createTask(_dto: CreateTaskDto) { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async updateTask(_taskId: string, _dto: UpdateTaskDto) { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async moveTask(_taskId: string, _targetColumnId: string, _targetPosition: number) { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async deleteTask(_taskId: string): Promise<void> { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async getLabels(_boardId: string) { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async createLabel(_boardId: string, _name: string, _color: string) { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  {{/if}}
}
