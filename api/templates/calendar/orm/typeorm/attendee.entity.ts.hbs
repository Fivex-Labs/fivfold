import {
  Entity,
  PrimaryGeneratedColumn,
  Column,
  CreateDateColumn,
  ManyToOne,
  JoinColumn,
} from 'typeorm';
import { CalendarEvent } from './event.entity';

@Entity('calendar_attendees')
export class CalendarAttendee {
  @PrimaryGeneratedColumn('uuid')
  id: string;

  @Column({ type: 'varchar', name: 'event_id' })
  eventId: string;

  @Column({ type: 'varchar', name: 'user_id', nullable: true })
  userId: string | null; // Optional FK to your User entity

  @Column({ type: 'varchar', length: 255 })
  email: string;

  @Column({ type: 'varchar', length: 50, nullable: true })
  name: string | null;

  @Column({ type: 'varchar', length: 20, default: 'pending' })
  status: 'pending' | 'accepted' | 'declined';

  @ManyToOne(() => CalendarEvent, (event) => event.attendees, { onDelete: 'CASCADE' })
  @JoinColumn({ name: 'event_id' })
  event: CalendarEvent;

  @CreateDateColumn({ name: 'created_at' })
  createdAt: Date;
}
