import { IsEnum, IsISO8601, IsOptional } from 'class-validator';

export class QueryEventsDto {
  @IsISO8601()
  @IsOptional()
  startDate?: string;

  @IsISO8601()
  @IsOptional()
  endDate?: string;

  @IsEnum(['default', 'red', 'orange', 'yellow', 'green', 'teal', 'blue', 'purple', 'pink'])
  @IsOptional()
  color?: string;
}
