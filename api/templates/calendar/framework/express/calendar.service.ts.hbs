  async createEvent(_userId: string, _dto: CreateEventDto): Promise<unknown> { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async updateEvent(_userId: string, _eventId: string, _dto: UpdateEventDto): Promise<unknown> { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async deleteEvent(_userId: string, _eventId: string): Promise<void> { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async addAttendee(_eventId: string, _email: string, _userId?: string): Promise<unknown> { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async removeAttendee(_eventId: string, _attendeeId: string): Promise<void> { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  async updateAttendeeStatus(_eventId: string, _attendeeId: string, _status: 'pending' | 'accepted' | 'declined'): Promise<unknown> { throw new Error(`{{moduleName}}Service not implemented for ORM: {{orm}}. Implement for your chosen database.`); }
  {{/if}}
}
