import { Router, type Request, type Response, type NextFunction } from 'express';
import { {{moduleName}}Service } from './{{kitName}}.service';

// Replace with your actual authentication middleware
function authMiddleware(req: Request, res: Response, next: NextFunction): void {
  // TODO: Replace with your auth check
  next();
}

function getUser(req: Request): { id: string } {
  return (req as any).user ?? { id: 'REPLACE_WITH_USER_ID' };
}

/** Create router with injected service. Use create{{moduleName}}Service(connection) to create the service. */
export function create{{moduleName}}Router(service: {{moduleName}}Service): Router {
  const router = Router();

  router.use(authMiddleware);

  // GET /calendar/events?startDate=...&endDate=...
  router.get('/events', async (req, res) => {
    try {
      const { startDate, endDate } = req.query as Record<string, string>;
      if (startDate && endDate) {
        res.json(await service.getEventsByDateRange(getUser(req).id, new Date(startDate), new Date(endDate)));
      } else {
        res.json(await service.getEvents(getUser(req).id));
      }
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // GET /calendar/events/:eventId
  router.get('/events/:eventId', async (req, res) => {
    try {
      const event = await service.getEvent(getUser(req).id, req.params['eventId']!);
      if (!event) return res.status(404).json({ error: 'Not found' });
      res.json(event);
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // POST /calendar/events
  router.post('/events', async (req, res) => {
    try {
      res.status(201).json(await service.createEvent(getUser(req).id, req.body));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // PATCH /calendar/events/:eventId
  router.patch('/events/:eventId', async (req, res) => {
    try {
      res.json(await service.updateEvent(getUser(req).id, req.params['eventId']!, req.body));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // DELETE /calendar/events/:eventId
  router.delete('/events/:eventId', async (req, res) => {
    try {
      await service.deleteEvent(getUser(req).id, req.params['eventId']!);
      res.status(204).send();
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // POST /calendar/events/:eventId/attendees
  router.post('/events/:eventId/attendees', async (req, res) => {
    try {
      const { email, userId } = req.body;
      res.status(201).json(await service.addAttendee(req.params['eventId']!, email, userId));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // DELETE /calendar/events/:eventId/attendees/:attendeeId
  router.delete('/events/:eventId/attendees/:attendeeId', async (req, res) => {
    try {
      await service.removeAttendee(req.params['eventId']!, req.params['attendeeId']!);
      res.status(204).send();
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  // PATCH /calendar/events/:eventId/attendees/:attendeeId/status
  router.patch('/events/:eventId/attendees/:attendeeId/status', async (req, res) => {
    try {
      const { status } = req.body;
      res.json(await service.updateAttendeeStatus(req.params['eventId']!, req.params['attendeeId']!, status));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  /**
   * POST /calendar/events/:eventId/reminders
   *
   * Stub endpoint — wire up your own notification service here.
   * Supported services: Firebase Cloud Messaging (FCM), AWS SNS, OneSignal, Twilio, etc.
   * Body: { minutes: number; method?: "notification" | "email" | "sms" }
   */
  router.post('/events/:eventId/reminders', async (req, res) => {
    try {
      const { minutes, method } = req.body;
      res.status(201).json(await service.addReminder(getUser(req).id, req.params['eventId']!, minutes, method));
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  /**
   * DELETE /calendar/events/:eventId/reminders/:reminderId
   *
   * Stub endpoint — implement cancellation in your notification service.
   */
  router.delete('/events/:eventId/reminders/:reminderId', async (req, res) => {
    try {
      await service.removeReminder(getUser(req).id, req.params['eventId']!, req.params['reminderId']!);
      res.status(204).send();
    } catch (err) { res.status(500).json({ error: String(err) }); }
  });

  return router;
}
