{
  "name": "push",
  "version": "1.0.0",
  "description": "Push notifications backend with device registration, sending, logging, and pluggable providers (FCM, OneSignal, AWS SNS, Pushy, Pusher Beams).",
  "serviceProviderPrompt": {
    "message": "Which push notification service do you want to use?",
    "labels": {
      "fcm": "Firebase Cloud Messaging (FCM)",
      "onesignal": "OneSignal",
      "sns": "AWS SNS",
      "pushy": "Pushy",
      "pusher-beams": "Pusher Beams"
    }
  },
  "domain": {
    "files": [
      { "template": "push/domain/push.port.ts.hbs", "output": "{{outputDir}}/{{kitName}}/domain/push.port.ts" },
      { "template": "push/domain/dto/send-notification.dto.ts.hbs", "output": "{{outputDir}}/{{kitName}}/dto/send-notification.dto.ts" },
      { "template": "push/domain/dto/register-device.dto.ts.hbs", "output": "{{outputDir}}/{{kitName}}/dto/register-device.dto.ts" },
      { "template": "push/domain/dto/send-to-topic.dto.ts.hbs", "output": "{{outputDir}}/{{kitName}}/dto/send-to-topic.dto.ts" }
    ]
  },
  "framework": {
    "express": {
      "files": [
        { "template": "push/framework/express/push.routes.ts.hbs", "output": "{{outputDir}}/{{kitName}}/push.routes.ts" },
        { "template": "push/framework/express/push.service.ts.hbs", "output": "{{outputDir}}/{{kitName}}/push.service.ts" }
      ],
      "dependencies": ["class-validator", "class-transformer", "express", "uuid"],
      "devDependencies": ["@types/express", "@types/uuid"],
      "astMutations": [
        { "target": "src/app.ts", "action": "registerMiddleware", "routePath": "/api/push", "importPath": "./modules/push/push.routes", "importName": "createPushRouter" }
      ]
    },
    "nestjs": {
      "files": [
        { "template": "push/framework/nestjs/push.module.ts.hbs", "output": "{{outputDir}}/{{kitName}}/push.module.ts" },
        { "template": "push/framework/nestjs/push.controller.ts.hbs", "output": "{{outputDir}}/{{kitName}}/push.controller.ts" },
        { "template": "push/framework/nestjs/push.service.ts.hbs", "output": "{{outputDir}}/{{kitName}}/push.service.ts" }
      ],
      "dependencies": ["class-validator", "class-transformer", "@nestjs/common", "@nestjs/core", "uuid"],
      "devDependencies": ["@types/uuid"],
      "astMutations": [
        { "target": "src/app.module.ts", "action": "registerModule", "module": "PushModule", "importPath": "./modules/push/push.module" }
      ]
    }
  },
  "orm": {
    "typeorm": {
      "files": [
        { "template": "push/orm/typeorm/push-subscription.entity.ts.hbs", "output": "{{outputDir}}/{{kitName}}/entities/push-subscription.entity.ts" },
        { "template": "push/orm/typeorm/notification-log.entity.ts.hbs", "output": "{{outputDir}}/{{kitName}}/entities/notification-log.entity.ts" }
      ],
      "dependencies": ["typeorm", "pg", "reflect-metadata"],
      "devDependencies": ["@types/pg"]
    },
    "prisma": {
      "files": [
        { "template": "push/orm/prisma/push-models.prisma.hbs", "output": "prisma/schema.prisma", "mode": "append" }
      ],
      "dependencies": ["@prisma/client"],
      "devDependencies": ["prisma"]
    },
    "mongoose": {
      "files": [
        { "template": "push/orm/mongoose/push-subscription.schema.ts.hbs", "output": "{{outputDir}}/{{kitName}}/schemas/push-subscription.schema.ts" },
        { "template": "push/orm/mongoose/notification-log.schema.ts.hbs", "output": "{{outputDir}}/{{kitName}}/schemas/notification-log.schema.ts" }
      ],
      "dependencies": ["mongoose"],
      "devDependencies": []
    },
    "cosmos-sdk": {
      "files": [
        { "template": "push/orm/cosmos-sdk/push-containers.ts.hbs", "output": "{{outputDir}}/{{kitName}}/containers/push.containers.ts" }
      ],
      "dependencies": ["@azure/cosmos"],
      "devDependencies": [],
      "envVars": ["COSMOS_ENDPOINT", "COSMOS_KEY", "COSMOS_DATABASE_ID"]
    },
    "dynamodb-sdk": {
      "files": [
        { "template": "push/orm/dynamodb-sdk/push-tables.ts.hbs", "output": "{{outputDir}}/{{kitName}}/tables/push.tables.ts" }
      ],
      "dependencies": ["@aws-sdk/client-dynamodb", "@aws-sdk/lib-dynamodb"],
      "devDependencies": [],
      "envVars": ["AWS_REGION", "AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY"]
    }
  },
  "services": {
    "fcm": {
      "files": [
        { "template": "push/services/fcm/fcm-push.adapter.ts.hbs", "output": "{{outputDir}}/{{kitName}}/adapters/fcm-push.adapter.ts" }
      ],
      "dependencies": ["firebase-admin"],
      "envVars": ["FIREBASE_PROJECT_ID", "FIREBASE_CLIENT_EMAIL", "FIREBASE_PRIVATE_KEY"]
    },
    "onesignal": {
      "files": [
        { "template": "push/services/onesignal/onesignal-push.adapter.ts.hbs", "output": "{{outputDir}}/{{kitName}}/adapters/onesignal-push.adapter.ts" }
      ],
      "dependencies": ["axios"],
      "envVars": ["ONESIGNAL_APP_ID", "ONESIGNAL_REST_API_KEY"]
    },
    "sns": {
      "files": [
        { "template": "push/services/sns/aws-sns-push.adapter.ts.hbs", "output": "{{outputDir}}/{{kitName}}/adapters/aws-sns-push.adapter.ts" }
      ],
      "dependencies": ["@aws-sdk/client-sns"],
      "envVars": ["AWS_REGION", "AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY"]
    },
    "pushy": {
      "files": [
        { "template": "push/services/pushy/pushy-push.adapter.ts.hbs", "output": "{{outputDir}}/{{kitName}}/adapters/pushy-push.adapter.ts" }
      ],
      "dependencies": ["pushy"],
      "envVars": ["PUSHY_API_KEY"]
    },
    "pusher-beams": {
      "files": [
        { "template": "push/services/pusher-beams/pusher-beams-push.adapter.ts.hbs", "output": "{{outputDir}}/{{kitName}}/adapters/pusher-beams-push.adapter.ts" }
      ],
      "dependencies": ["@pusher/push-notifications-server"],
      "envVars": ["PUSHER_BEAMS_INSTANCE_ID", "PUSHER_BEAMS_SECRET_KEY"]
    }
  }
}
