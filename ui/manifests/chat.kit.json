{
  "name": "chat",
  "version": "1.0.0",
  "description": "Complete iMessage/WhatsApp-inspired chat UI with threads, conversations, groups, attachments, polls, reactions, GIFs, location sharing, and real-time messaging. Built on shadcn/ui with glassmorphism design.",
  "dependencies": ["framer-motion", "date-fns", "emoji-mart"],
  "shadcnDependencies": [
    "button",
    "input",
    "textarea",
    "dropdown-menu",
    "card",
    "dialog",
    "scroll-area",
    "avatar",
    "badge",
    "separator",
    "tooltip",
    "popover",
    "command",
    "context-menu",
    "tabs",
    "toggle",
    "sheet"
  ],
  "files": [
    { "template": "chat/types.ts.hbs", "output": "{{outputDir}}/{{kitName}}/types.ts" },
    { "template": "chat/index.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/index.tsx" },
    { "template": "chat/threads-list.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/threads-list.tsx" },
    { "template": "chat/thread-item.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/thread-item.tsx" },
    { "template": "chat/conversation.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/conversation.tsx" },
    { "template": "chat/message-bubble.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/message-bubble.tsx" },
    { "template": "chat/message-input.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/message-input.tsx" },
    { "template": "chat/typing-indicator.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/typing-indicator.tsx" },
    { "template": "chat/attachment-picker.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/attachment-picker.tsx" },
    { "template": "chat/gif-picker.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/gif-picker.tsx" },
    { "template": "chat/poll-creator.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/poll-creator.tsx" },
    { "template": "chat/poll-display.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/poll-display.tsx" },
    { "template": "chat/location-picker.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/location-picker.tsx" },
    { "template": "chat/location-display.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/location-display.tsx" },
    { "template": "chat/reaction-picker.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/reaction-picker.tsx" },
    { "template": "chat/chat-avatar.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/chat-avatar.tsx" },
    { "template": "chat/search-panel.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/search-panel.tsx" },
    { "template": "chat/new-chat-dialog.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/new-chat-dialog.tsx" },
    { "template": "chat/contact-detail.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/contact-detail.tsx" },
    { "template": "chat/group-detail.tsx.hbs", "output": "{{outputDir}}/{{kitName}}/group-detail.tsx" }
  ]
}
