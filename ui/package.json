{
  "name": "@fivfold/ui",
  "version": "0.13.3",
  "description": "FivFold UI -- full-stack Kits for React & Next.js, built on shadcn/ui",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "fivfold": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "manifests",
    "templates",
    "skills",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.cli.config.ts",
    "dev": "tsup --config tsup.cli.config.ts --watch",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "fivfold",
    "kit",
    "ui",
    "react",
    "nextjs",
    "next.js",
    "tailwindcss",
    "tailwind",
    "shadcn",
    "shadcn-ui",
    "cli",
    "scaffolding",
    "components",
    "full-stack",
    "node",
    "node.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fivex-Labs/fivfold.git"
  },
  "homepage": "https://fold.fivexlabs.com/",
  "author": "Fivex Labs",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@fivfold/core": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.17.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
