'use client';

import { formatDistanceToNow } from 'date-fns';
import {
  Pin,
  BellOff,
  MoreHorizontal,
  Eye,
  EyeOff,
  Bell,
  Trash2,
  Users,
} from 'lucide-react';
import { cn } from '@/lib/utils';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from '@/components/ui/dropdown-menu';
import { ChatAvatar, GroupAvatar } from './chat-avatar';
import type { FivFoldChatConversation } from './types';

interface ThreadItemProps {
  conversation: FivFoldChatConversation;
  currentUserId: string;
  isSelected?: boolean;
  onClick: () => void;
  onPin?: (conversationId: string, pinned: boolean) => void;
  onMute?: (conversationId: string, mutedUntil: Date | null) => void;
  onDelete?: (conversationId: string) => void;
  onMarkAsRead?: (conversationId: string) => void;
  onMarkAsUnread?: (conversationId: string) => void;
}

function getConversationDisplayName(
  conversation: FivFoldChatConversation,
  currentUserId: string
): string {
  if (conversation.name) return conversation.name;
  const other = conversation.participants.find((p) => p.id !== currentUserId);
  return other?.name ?? 'Unknown';
}

function getLastMessagePreview(conversation: FivFoldChatConversation): string {
  const msg = conversation.lastMessage;
  if (!msg) return '';
  switch (msg.type) {
    case 'image': return '📷 Photo';
    case 'video': return '🎥 Video';
    case 'file': return '📎 File';
    case 'poll': return '📊 Poll';
    case 'location': return '📍 Location';
    case 'gif': return '🎞️ GIF';
    default: return msg.content ?? '';
  }
}

function truncate(text: string, max = 42): string {
  return text.length > max ? text.slice(0, max) + '…' : text;
}

export function ThreadItem({
  conversation,
  currentUserId,
  isSelected,
  onClick,
  onPin,
  onMute,
  onDelete,
  onMarkAsRead,
  onMarkAsUnread,
}: ThreadItemProps) {
  const displayName = getConversationDisplayName(conversation, currentUserId);
  const preview = truncate(getLastMessagePreview(conversation));
  const lastTime = conversation.lastMessage?.createdAt
    ? formatDistanceToNow(new Date(conversation.lastMessage.createdAt), { addSuffix: false })
    : '';
  const hasUnread = (conversation.unreadCount ?? 0) > 0;
  const otherParticipant = conversation.type === 'group'
    ? null
    : conversation.participants.find((p) => p.id !== currentUserId);

  return (
    <div
      className={cn(
        'group relative flex w-full items-stretch rounded-xl transition-colors',
        isSelected ? 'bg-primary/10 shadow-sm' : 'hover:bg-muted/60'
      )}
    >
      <button
        type="button"
        onClick={onClick}
        className={cn(
          'flex min-w-0 flex-1 items-center gap-3 px-3 py-2.5 text-left',
          'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring'
        )}
      >
        <div className="relative shrink-0">
          {conversation.type === 'group' ? (
            <GroupAvatar
              participants={conversation.participants.filter((p) => p.id !== currentUserId)}
              size="md"
            />
          ) : (
            <ChatAvatar
              src={otherParticipant?.avatarUrl}
              name={displayName}
              online={otherParticipant?.online}
              size="md"
            />
          )}
        </div>

        <div className="min-w-0 flex-1 pr-6">
          <div className="flex items-center justify-between gap-1">
            <span
              className={cn(
                'truncate text-sm',
                hasUnread ? 'font-semibold text-foreground' : 'font-medium text-foreground/80'
              )}
            >
              {conversation.isPinned && (
                <Pin className="mr-1 inline h-3 w-3 rotate-45 text-primary opacity-70" />
              )}
              {displayName}
              {conversation.type === 'group' && (
                <Users className="ml-1 inline h-3 w-3 opacity-60" />
              )}
            </span>
            <span className="shrink-0 text-[11px] text-muted-foreground group-hover:opacity-0">
              {lastTime}
            </span>
          </div>

          <div className="mt-0.5 flex items-center justify-between gap-1">
            <span
              className={cn(
                'truncate text-xs',
                hasUnread ? 'text-foreground/80' : 'text-muted-foreground'
              )}
            >
              {conversation.isMuted && (
                <BellOff className="mr-1 inline h-3 w-3 opacity-50" />
              )}
              {preview || <span className="italic">No messages yet</span>}
            </span>

            <div className="flex shrink-0 items-center gap-1 group-hover:opacity-0">
              {hasUnread && (
                <Badge
                  variant="default"
                  className="flex h-5 min-w-5 items-center justify-center rounded-full px-1.5 text-[10px] font-bold"
                >
                  {conversation.unreadCount > 99 ? '99+' : conversation.unreadCount}
                </Badge>
              )}
            </div>
          </div>
        </div>
      </button>

      <DropdownMenu>
        <DropdownMenuTrigger asChild>
          <Button
            type="button"
            variant="ghost"
            size="icon"
            className={cn(
              'absolute right-1 top-1/2 z-10 h-7 w-7 -translate-y-1/2 shrink-0',
              'text-muted-foreground opacity-0 transition-opacity hover:bg-muted hover:text-foreground',
              'group-hover:opacity-100 focus:opacity-100 data-[state=open]:opacity-100'
            )}
            aria-label="Conversation actions"
            onClick={(e) => e.stopPropagation()}
          >
            <MoreHorizontal className="h-4 w-4" />
          </Button>
        </DropdownMenuTrigger>
        <DropdownMenuContent align="end" className="w-52" onClick={(e) => e.stopPropagation()}>
          {hasUnread ? (
            <DropdownMenuItem
              onClick={() => onMarkAsRead?.(conversation.id)}
              disabled={!onMarkAsRead}
            >
              <Eye className="mr-2 h-3.5 w-3.5" />
              Mark as Read
            </DropdownMenuItem>
          ) : (
            <DropdownMenuItem
              onClick={() => onMarkAsUnread?.(conversation.id)}
              disabled={!onMarkAsUnread}
            >
              <EyeOff className="mr-2 h-3.5 w-3.5" />
              Mark as Unread
            </DropdownMenuItem>
          )}
          <DropdownMenuItem
            onClick={() =>
              onMute?.(
                conversation.id,
                conversation.isMuted ? null : new Date(Date.now() + 8 * 3600000)
              )
            }
            disabled={!onMute}
          >
            {conversation.isMuted ? (
              <>
                <Bell className="mr-2 h-3.5 w-3.5" />
                Unmute
              </>
            ) : (
              <>
                <BellOff className="mr-2 h-3.5 w-3.5" />
                Mute Notifications
              </>
            )}
          </DropdownMenuItem>
          <DropdownMenuItem
            onClick={() => onPin?.(conversation.id, !conversation.isPinned)}
            disabled={!onPin}
          >
            <Pin className="mr-2 h-3.5 w-3.5" />
            {conversation.isPinned ? 'Unpin' : 'Pin'} Conversation
          </DropdownMenuItem>
          <DropdownMenuSeparator />
          <DropdownMenuItem
            className="text-destructive focus:text-destructive"
            onClick={() => onDelete?.(conversation.id)}
            disabled={!onDelete}
          >
            <Trash2 className="mr-2 h-3.5 w-3.5" />
            Delete
          </DropdownMenuItem>
        </DropdownMenuContent>
      </DropdownMenu>
    </div>
  );
}
