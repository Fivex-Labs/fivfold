'use client';

import { useState, useMemo } from 'react';
import { Search, Edit3, X, MoreVertical, MessageSquare } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { ScrollArea } from '@/components/ui/scroll-area';
import {
  ContextMenu,
  ContextMenuContent,
  ContextMenuItem,
  ContextMenuSeparator,
  ContextMenuTrigger,
} from '@/components/ui/context-menu';
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuTrigger,
} from '@/components/ui/dropdown-menu';
import { ThreadItem } from './thread-item';
import type { FivFoldChatConversation, FivFoldChatMessage } from './types';

interface ThreadsListProps {
  conversations: FivFoldChatConversation[];
  messages?: Record<string, FivFoldChatMessage[]>;
  currentUserId: string;
  selectedConversationId: string | null;
  onSelectConversation: (conversation: FivFoldChatConversation) => void;
  onNewChat?: () => void;
  onOpenGlobalSearch?: () => void;
  onPin?: (conversationId: string, pinned: boolean) => void;
  onMute?: (conversationId: string, mutedUntil: Date | null) => void;
  onDeleteConversation?: (conversationId: string) => void;
  onMarkConversationRead?: (conversationId: string) => void;
  onMarkConversationUnread?: (conversationId: string) => void;
}

export function ThreadsList({
  conversations,
  messages = {},
  currentUserId,
  selectedConversationId,
  onSelectConversation,
  onNewChat,
  onOpenGlobalSearch,
  onPin,
  onMute,
  onDeleteConversation,
  onMarkConversationRead,
  onMarkConversationUnread,
}: ThreadsListProps) {
  const [sidebarSearchOpen, setSidebarSearchOpen] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');

  const filtered = useMemo(() => {
    const pinned: FivFoldChatConversation[] = [];
    const unpinned: FivFoldChatConversation[] = [];
    const q = searchQuery.trim().toLowerCase();

    const matchesSearch = (conv: FivFoldChatConversation) => {
      if (!q) return true;
      const name =
        conv.name ?? conv.participants.find((p) => p.id !== currentUserId)?.name ?? '';
      if (name.toLowerCase().includes(q)) return true;
      const msgs = messages[conv.id] ?? [];
      return msgs.some((m) => m.content?.toLowerCase().includes(q));
    };

    for (const conv of conversations) {
      if (!matchesSearch(conv)) continue;
      if (conv.isPinned) pinned.push(conv);
      else unpinned.push(conv);
    }

    const sortByLastMessage = (a: FivFoldChatConversation, b: FivFoldChatConversation) => {
      const ta = a.lastMessage?.createdAt ? new Date(a.lastMessage.createdAt).getTime() : 0;
      const tb = b.lastMessage?.createdAt ? new Date(b.lastMessage.createdAt).getTime() : 0;
      return tb - ta;
    };

    return [...pinned.sort(sortByLastMessage), ...unpinned.sort(sortByLastMessage)];
  }, [conversations, currentUserId, searchQuery, messages]);

  return (
    <div className="flex h-full flex-col bg-background/60">
      {/* Header — demo-style toggle into search */}
      {sidebarSearchOpen ? (
        <div className="flex items-center gap-2 border-b border-border/50 px-3 py-2.5">
          <Input
            autoFocus
            placeholder="Search messages…"
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
            className="h-8 flex-1 border-0 bg-transparent px-0 text-sm shadow-none focus-visible:ring-0"
          />
          <Button
            variant="ghost"
            size="icon"
            className="h-8 w-8 shrink-0 text-muted-foreground hover:text-foreground"
            onClick={() => {
              setSidebarSearchOpen(false);
              setSearchQuery('');
            }}
            aria-label="Close search"
          >
            <X className="h-4 w-4" />
          </Button>
        </div>
      ) : (
        <div className="flex items-center justify-between border-b border-border/50 px-4 py-3">
          <h1 className="text-lg font-bold tracking-tight">Messages</h1>
          <div className="flex items-center gap-1">
            <Button
              variant="ghost"
              size="icon"
              className="h-8 w-8"
              onClick={() => setSidebarSearchOpen(true)}
              aria-label="Search conversations"
            >
              <Search className="h-4 w-4" />
            </Button>
            <Button
              variant="ghost"
              size="icon"
              className="h-8 w-8"
              onClick={onNewChat}
              aria-label="New Chat"
            >
              <Edit3 className="h-4 w-4" />
            </Button>
            <DropdownMenu>
              <DropdownMenuTrigger asChild>
                <Button variant="ghost" size="icon" className="h-8 w-8" aria-label="More">
                  <MoreVertical className="h-4 w-4" />
                </Button>
              </DropdownMenuTrigger>
              <DropdownMenuContent align="end">
                <DropdownMenuItem
                  onClick={() => onOpenGlobalSearch?.()}
                  disabled={!onOpenGlobalSearch}
                >
                  <MessageSquare className="mr-2 h-3.5 w-3.5" />
                  Search all chats…
                </DropdownMenuItem>
              </DropdownMenuContent>
            </DropdownMenu>
          </div>
        </div>
      )}

      {/* Thread list */}
      <ScrollArea className="flex-1 px-2">
        <div className="space-y-0.5 pb-4 pt-1">
          {filtered.length === 0 ? (
            <div className="px-4 py-8 text-center text-sm text-muted-foreground">
              {searchQuery.trim() ? 'No results' : 'No conversations yet'}
            </div>
          ) : (
            filtered.map((conv) => (
              <ContextMenu key={conv.id}>
                <ContextMenuTrigger asChild>
                  <div>
                    <ThreadItem
                      conversation={conv}
                      currentUserId={currentUserId}
                      isSelected={conv.id === selectedConversationId}
                      onClick={() => onSelectConversation(conv)}
                      onPin={onPin}
                      onMute={onMute}
                      onDelete={onDeleteConversation}
                      onMarkAsRead={onMarkConversationRead}
                      onMarkAsUnread={onMarkConversationUnread}
                    />
                  </div>
                </ContextMenuTrigger>
                <ContextMenuContent>
                  <ContextMenuItem
                    onClick={() =>
                      (conv.unreadCount ?? 0) > 0
                        ? onMarkConversationRead?.(conv.id)
                        : onMarkConversationUnread?.(conv.id)
                    }
                  >
                    {(conv.unreadCount ?? 0) > 0 ? 'Mark as Read' : 'Mark as Unread'}
                  </ContextMenuItem>
                  <ContextMenuItem onClick={() => onPin?.(conv.id, !conv.isPinned)}>
                    {conv.isPinned ? 'Unpin' : 'Pin'} Conversation
                  </ContextMenuItem>
                  <ContextMenuItem
                    onClick={() =>
                      onMute?.(conv.id, conv.isMuted ? null : new Date(Date.now() + 8 * 3600000))
                    }
                  >
                    {conv.isMuted ? 'Unmute' : 'Mute'} Notifications
                  </ContextMenuItem>
                  <ContextMenuSeparator />
                  <ContextMenuItem
                    className="text-destructive"
                    onClick={() => onDeleteConversation?.(conv.id)}
                  >
                    Delete Conversation
                  </ContextMenuItem>
                </ContextMenuContent>
              </ContextMenu>
            ))
          )}
        </div>
      </ScrollArea>
    </div>
  );
}
