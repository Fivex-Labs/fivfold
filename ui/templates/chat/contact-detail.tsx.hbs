'use client';

import React from 'react';
import { X, Image } from 'lucide-react';
import { format } from 'date-fns';
import { Button } from '@/components/ui/button';
import { Separator } from '@/components/ui/separator';
import { ScrollArea } from '@/components/ui/scroll-area';
import { ChatAvatar } from './chat-avatar';
import type { FivFoldChatUser } from './types';

interface ContactDetailProps {
  user: FivFoldChatUser;
  sharedMedia?: Array<{ id: string; type: 'image' | 'video'; url: string; thumbnailUrl?: string }>;
  onClose: () => void;
}

export function ContactDetail({ user, sharedMedia = [], onClose }: ContactDetailProps) {
  return (
    <div className="flex h-full flex-col bg-background/80 backdrop-blur-sm">
      <div className="flex items-center justify-between border-b border-border/50 px-4 py-3">
        <h2 className="font-semibold">Contact Info</h2>
        <Button variant="ghost" size="icon" className="h-8 w-8" onClick={onClose}>
          <X className="h-4 w-4" />
        </Button>
      </div>

      <ScrollArea className="flex-1">
        <div className="space-y-6 p-4">
          {/* Avatar + name */}
          <div className="flex flex-col items-center gap-3 py-4">
            <ChatAvatar
              src={user.avatarUrl}
              name={user.name}
              size="xl"
              online={user.online}
            />
            <div className="text-center">
              <p className="text-lg font-bold">{user.name}</p>
              <p className="text-sm text-muted-foreground">
                {user.online
                  ? 'Online'
                  : user.lastSeen
                    ? `Last seen ${format(new Date(user.lastSeen), 'PPp')}`
                    : 'Offline'}
              </p>
            </div>
          </div>

          <Separator />

          {/* Shared media */}
          {sharedMedia.length > 0 && (
            <div>
              <div className="mb-2 flex items-center justify-between">
                <h3 className="text-sm font-semibold">Shared Media</h3>
                <span className="text-xs text-muted-foreground">{sharedMedia.length}</span>
              </div>
              <div className="grid grid-cols-3 gap-1">
                {sharedMedia.slice(0, 9).map((item) => (
                  <div key={item.id} className="aspect-square overflow-hidden rounded-lg">
                    <img
                      src={item.thumbnailUrl ?? item.url}
                      alt="media"
                      className="h-full w-full object-cover"
                    />
                  </div>
                ))}
              </div>
            </div>
          )}

          {sharedMedia.length === 0 && (
            <div className="flex flex-col items-center gap-2 py-8 text-muted-foreground">
              <Image className="h-8 w-8 opacity-30" />
              <p className="text-sm">No shared media</p>
            </div>
          )}
        </div>
      </ScrollArea>
    </div>
  );
}
