'use client';

import { useRef, useState, type ChangeEvent, type DragEvent } from 'react';
import { Upload, Image, Film, FileText, Headphones } from 'lucide-react';
import { cn } from '@/lib/utils';
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
} from '@/components/ui/dialog';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Button } from '@/components/ui/button';
import type { FivFoldChatAttachment } from './types';

type AttachmentPickerPayload = Omit<FivFoldChatAttachment, 'id' | 'messageId'>;

interface AttachmentPickerProps {
  open: boolean;
  onClose: () => void;
  onSelect: (attachment: AttachmentPickerPayload) => void;
}

const ACCEPT_BY_TYPE: Record<string, string> = {
  image: 'image/*',
  video: 'video/*',
  file: '*/*',
  audio: 'audio/*',
};

export function AttachmentPicker({ open, onClose, onSelect }: AttachmentPickerProps) {
  const [preview, setPreview] = useState<{ url: string; name: string; type: string; size: number; mimeType: string } | null>(null);
  const [activeTab, setActiveTab] = useState<'image' | 'video' | 'file' | 'audio'>('image');
  const inputRef = useRef<HTMLInputElement>(null);

  const handleFileChange = (e: ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const objectUrl = URL.createObjectURL(file);
    setPreview({ url: objectUrl, name: file.name, type: activeTab, size: file.size, mimeType: file.type });
  };

  const handleDrop = (e: DragEvent<HTMLDivElement>) => {
    e.preventDefault();
    const file = e.dataTransfer.files?.[0];
    if (!file) return;
    const objectUrl = URL.createObjectURL(file);
    const type = file.type.startsWith('image/') ? 'image'
      : file.type.startsWith('video/') ? 'video'
      : file.type.startsWith('audio/') ? 'audio'
      : 'file';
    setPreview({ url: objectUrl, name: file.name, type, size: file.size, mimeType: file.type });
  };

  const handleSend = () => {
    if (!preview) return;
    onSelect({
      type: preview.type as FivFoldChatAttachment['type'],
      url: preview.url,
      name: preview.name,
      size: preview.size,
      mimeType: preview.mimeType,
    });
    setPreview(null);
    onClose();
  };

  const handleCancel = () => {
    setPreview(null);
    if (inputRef.current) inputRef.current.value = '';
    onClose();
  };

  return (
    <Dialog open={open} onOpenChange={(open) => !open && handleCancel()}>
      <DialogContent className="max-w-md">
        <DialogHeader>
          <DialogTitle>Send Attachment</DialogTitle>
        </DialogHeader>

        {preview ? (
          <div className="space-y-4">
            {preview.type === 'image' && (
              <img src={preview.url} alt={preview.name} className="w-full rounded-lg object-contain max-h-64" />
            )}
            {preview.type === 'video' && (
              <video src={preview.url} controls className="w-full rounded-lg max-h-64" />
            )}
            {(preview.type === 'file' || preview.type === 'audio') && (
              <div className="flex items-center gap-3 rounded-lg bg-muted p-3">
                <FileText className="h-8 w-8 text-muted-foreground" />
                <div>
                  <p className="text-sm font-medium">{preview.name}</p>
                  <p className="text-xs text-muted-foreground">{(preview.size / 1024).toFixed(1)} KB</p>
                </div>
              </div>
            )}

            <div className="flex gap-2">
              <Button variant="outline" className="flex-1" onClick={() => setPreview(null)}>
                Change
              </Button>
              <Button className="flex-1" onClick={handleSend}>
                Send
              </Button>
            </div>
          </div>
        ) : (
          <Tabs value={activeTab} onValueChange={(v) => setActiveTab(v as typeof activeTab)}>
            <TabsList className="w-full">
              <TabsTrigger value="image" className="flex-1"><Image className="mr-1 h-3.5 w-3.5" />Photo</TabsTrigger>
              <TabsTrigger value="video" className="flex-1"><Film className="mr-1 h-3.5 w-3.5" />Video</TabsTrigger>
              <TabsTrigger value="file" className="flex-1"><FileText className="mr-1 h-3.5 w-3.5" />File</TabsTrigger>
              <TabsTrigger value="audio" className="flex-1"><Headphones className="mr-1 h-3.5 w-3.5" />Audio</TabsTrigger>
            </TabsList>

            {(['image', 'video', 'file', 'audio'] as const).map((tab) => (
              <TabsContent key={tab} value={tab}>
                <div
                  className={cn(
                    'flex flex-col items-center justify-center gap-3 rounded-xl border-2 border-dashed',
                    'border-border/50 p-8 text-center transition-colors',
                    'hover:border-primary/50 hover:bg-muted/30'
                  )}
                  onDrop={handleDrop}
                  onDragOver={(e) => e.preventDefault()}
                >
                  <Upload className="h-8 w-8 text-muted-foreground" />
                  <div>
                    <p className="text-sm font-medium">Drop your {tab} here</p>
                    <p className="text-xs text-muted-foreground">or click to browse</p>
                  </div>
                  <input
                    ref={inputRef}
                    type="file"
                    accept={ACCEPT_BY_TYPE[tab]}
                    className="hidden"
                    onChange={handleFileChange}
                    onClick={() => setActiveTab(tab)}
                  />
                  <Button
                    variant="outline"
                    size="sm"
                    onClick={() => {
                      setActiveTab(tab);
                      inputRef.current?.click();
                    }}
                  >
                    Browse
                  </Button>
                </div>
              </TabsContent>
            ))}
          </Tabs>
        )}
      </DialogContent>
    </Dialog>
  );
}
